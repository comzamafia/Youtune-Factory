# ─────────────────────────────────────────────────────────────────────
# AI YouTube Novel Factory — Environment Configuration
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────

# ── Database ──
DATABASE_URL=postgresql://postgres:password@localhost:5432/aiyoutube
POSTGRES_PASSWORD=password

# ── Redis (Celery Broker) ──
REDIS_URL=redis://localhost:6379/0

# ── CORS (comma-separated list of allowed origins) ──────────────────────
# Development: CORS_ORIGINS=* (allow all)
# Production:  CORS_ORIGINS=https://yourdomain.com,https://admin.yourdomain.com
CORS_ORIGINS=*

# ── API Security ──
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
API_SECRET_KEY=change-me-to-a-secure-random-string

# ── LLM (OpenAI-compatible endpoint) ──
LLM_API_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=qwen3.5
# Per-request chunk size (must fit model context window, ~3000 chars ≈ 2K tokens)
LLM_CHUNK_MAX_CHARS=3000

# ── TTS Engine ──
# Options: coqui, elevenlabs, edge_tts
TTS_ENGINE=edge_tts
# Thai voices: th-TH-PremwadeeNeural (female), th-TH-NiwatNeural (male)
EDGE_TTS_VOICE=th-TH-PremwadeeNeural
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ── Image Generation ──
# Options: stable_diffusion, comfyui, replicate, placeholder
IMAGE_ENGINE=stable_diffusion
SD_API_URL=http://localhost:7860
COMFYUI_API_URL=http://localhost:8188
# Replicate (cloud GPU — best for Railway/serverless deployments)
# Get API key at: https://replicate.com/account/api-tokens
REPLICATE_API_KEY=
REPLICATE_MODEL_ID=stability-ai/sdxl:39ed52f2319f9f5d3c65f7b5d7f756b8d5c5e5e5

# ── YouTube ──
# Download from https://console.cloud.google.com → OAuth 2.0 credentials
YOUTUBE_CLIENT_SECRET_FILE=client_secret.json
YOUTUBE_CREDENTIALS_FILE=youtube_credentials.json

# ── GPU / FFmpeg ──
USE_GPU=true
FFMPEG_HWACCEL=cuda
FFMPEG_VCODEC=h264_nvenc
# Parallel FFmpeg render workers (set to CPU count for CPU-only machines)
FFMPEG_MAX_WORKERS=4

# ── Long-Content / Multi-Part Video ──────────────────────────────────
# How many scenes per video part (0 = unlimited single video)
MAX_SCENES_PER_PART=150
# Hard cap on total scenes for a single novel
MAX_TOTAL_SCENES=3000
# Max concurrent image AI tasks (prevents GPU OOM; raise if >24 GB VRAM)
IMAGE_TASK_CONCURRENCY=2
# Max concurrent TTS tasks
VOICE_TASK_CONCURRENCY=4
# Minimum free disk space in GB before starting render
MIN_FREE_DISK_GB=10.0
# Delete per-scene clips after final video is built (saves disk)
CLEANUP_CLIPS_AFTER_BUILD=true

# ── Flower Monitoring UI ──────────────────────────────────────────────
FLOWER_USER=admin
FLOWER_PASSWORD=admin

